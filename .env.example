# ADAPT-OPS Configuration

# ─── MAB Configuration ────────────────────────────────
# Alpha parameter controls exploration vs exploitation trade-off
# Higher = more exploration, Lower = more exploitation
MAB_ALPHA=1.0

# Dimensionality of context vector (pipeline context features)
MAB_CONTEXT_DIM=16

# ─── Healing Configuration ───────────────────────────
# Minimum seconds between consecutive healing actions
# Prevents thrashing when multiple anomalies are detected
HEALING_COOLDOWN_SECS=60.0

# Minimum severity to trigger healing (1=LOW, 2=MEDIUM, 3=HIGH, 4=CRITICAL)
HEALING_MIN_SEVERITY=2

# ─── Anomaly Detection ──────────────────────────────
# Number of historical points to consider for Z-score calculation
ANOMALY_WINDOW_SIZE=30

# Minimum anomaly score to report anomaly (0.0 to 1.0)
ANOMALY_MIN_SCORE=0.45

# ─── API Server ─────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# ─── Persistence ────────────────────────────────────
# Enable saving/loading MAB state between restarts
ENABLE_MAB_PERSISTENCE=true

# Enable storing metrics history for analysis
ENABLE_METRICS_HISTORY=true

# Maximum number of metrics to store in memory
MAX_HISTORY_SIZE=10000

# ─── Logging ────────────────────────────────────────
LOG_LEVEL=INFO

# ─── GitHub Integration (Optional) ──────────────────
# GitHub API token for fetching workflow metrics
GITHUB_API_TOKEN=

# Webhook secret for GitHub Actions integration
GITHUB_WEBHOOK_SECRET=
